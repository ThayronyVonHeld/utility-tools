<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="500.0"
            prefWidth="750.0"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.sgr.utilitytools_v1.phonescontacts.PhonesContactsController"
            stylesheets="@phonescontacts.css"
            styleClass="root">

    <!-- Cabeçalho -->
    <top>
        <VBox spacing="12" styleClass="header">

            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <Label text="📞 Contatos e Ramais"
                   styleClass="title"/>

            <HBox spacing="10">

                <ChoiceBox fx:id="myChoiceBox"
                           prefWidth="180"
                           prefHeight="35"/>

                <Button text="+ Novo"
                        onAction="#addContatos"
                        styleClass="primary-button"/>

                <Button text="✎ Editar"/>

            </HBox>

        </VBox>
    </top>

    <!-- Conteúdo -->
    <center>

        <StackPane>

            <!-- Lista -->
            <VBox spacing="10">

                <padding>
                    <Insets top="15" right="20" bottom="20" left="20"/>
                </padding>

                <TextField promptText="🔍 Pesquisar contato..."
                           prefHeight="35"/>

                <ListView fx:id="lista"
                          VBox.vgrow="ALWAYS"/>

            </VBox>

            <!-- Modal -->
            <Pane fx:id="paineadd"
                  visible="false"
                  styleClass="modal-background">

                <children>

                    <VBox spacing="15"
                          layoutX="175"
                          layoutY="70"
                          prefWidth="400"
                          styleClass="modal-card">

                        <Label text="Adicionar Contato"
                               styleClass="subtitle"/>

                        <Label text="Nome"/>
                        <TextField fx:id="name"
                                   promptText="Digite o nome"/>

                        <Label text="Telefone"/>
                        <TextField fx:id="telefone"
                                   promptText="Digite o telefone"/>

                        <Label text="Praça"/>
                        <ChoiceBox fx:id="atribuir"/>

                        <HBox spacing="15">

                            <Button text="Cancelar"/>

                            <Button text="Salvar"
                                    onAction="#salvarContato"
                                    styleClass="success-button"/>

                        </HBox>

                    </VBox>

                </children>

            </Pane>

        </StackPane>

    </center>

</BorderPane>